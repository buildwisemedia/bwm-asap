---
import BaseLayout from '../layouts/BaseLayout.astro';
import site from '../data/site.json';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "PestControlService",
  "name": site.name,
  "description": site.description,
  "url": site.url,
  "telephone": site.phoneTel,
  "email": site.email,
  "address": {
    "@type": "PostalAddress",
    "streetAddress": site.address.street,
    "addressLocality": site.address.city,
    "addressRegion": site.address.state,
    "postalCode": site.address.zip,
    "addressCountry": "US"
  },
  "openingHoursSpecification": site.hours.schema.map(h => ({
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"],
    "opens": "00:00",
    "closes": "23:59"
  })),
  "areaServed": site.serviceAreas.map(area => ({
    "@type": "City",
    "name": area + ", GA"
  })),
  "priceRange": "$$",
  "image": `${site.url}/favicon.svg`,
  "sameAs": []
};

const testimonials = [
  {
    name: "Marcus T.",
    location: "East Point, GA",
    text: "Raccoons were in our attic for weeks. ASAP came same day, removed them humanely, and sealed every opening. Haven't had a problem since."
  },
  {
    name: "Denise W.",
    location: "Decatur, GA",
    text: "Professional, kind, and thorough. They explained everything before they started and cleaned up when they were done. Highly recommend."
  },
  {
    name: "Robert J.",
    location: "Marietta, GA",
    text: "Called at 6 AM about a snake in my garage. Ray was there within the hour. Calm, knowledgeable, and fair pricing. Five stars."
  }
];
---

<BaseLayout title="Home" jsonLd={jsonLd}>

  {/* ===== HERO ===== */}
  <section class="bg-forest relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-forest to-dark/80 opacity-90"></div>
    <div class="relative max-w-container mx-auto px-4 sm:px-6 py-20 md:py-28 lg:py-36">
      <div class="max-w-3xl">
        <p class="inline-block bg-amber/20 text-amber font-display font-semibold text-sm px-4 py-1.5 rounded-full mb-6">
          Licensed & Insured | 24/6 Emergency Service
        </p>
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-display font-bold text-white leading-tight mb-6">
          One Call. Problem Solved.<br />
          <span class="text-amber">Peace Restored.</span>
        </h1>
        <p class="text-lg sm:text-xl text-white/80 mb-8 max-w-2xl leading-relaxed">
          Metro Atlanta's trusted team for humane wildlife removal and effective pest control. Family-run. Georgia-licensed. Same-day service available.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a
            href={`tel:${site.phoneTel}`}
            class="inline-flex items-center justify-center gap-2 bg-amber hover:bg-amber/90 text-dark font-display font-bold px-8 py-4 rounded-lg text-lg transition-colors shadow-lg"
          >
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            Call Now: {site.phone}
          </a>
          <a
            href="/contact/"
            class="inline-flex items-center justify-center gap-2 bg-white/10 hover:bg-white/20 text-white font-display font-bold px-8 py-4 rounded-lg text-lg transition-colors border border-white/20"
          >
            Schedule Free Inspection
          </a>
        </div>
      </div>
    </div>
  </section>

  {/* ===== TRUST BAR ===== */}
  <section class="bg-white border-b border-border">
    <div class="max-w-container mx-auto px-4 sm:px-6 py-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-8">
        <div class="text-center">
          <div class="w-12 h-12 mx-auto mb-3 bg-forest/10 rounded-full flex items-center justify-center">
            <svg class="w-6 h-6 text-forest" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <p class="font-display font-bold text-charcoal text-lg">24/6 Service</p>
          <p class="text-gray text-sm">Mon-Sat, always on call</p>
        </div>
        <div class="text-center">
          <div class="w-12 h-12 mx-auto mb-3 bg-forest/10 rounded-full flex items-center justify-center">
            <svg class="w-6 h-6 text-forest" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
          </div>
          <p class="font-display font-bold text-charcoal text-lg">State Licensed</p>
          <p class="text-gray text-sm">GA DNR & Dept of Agriculture</p>
        </div>
        <div class="text-center">
          <div class="w-12 h-12 mx-auto mb-3 bg-forest/10 rounded-full flex items-center justify-center">
            <svg class="w-6 h-6 text-forest" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
            </svg>
          </div>
          <p class="font-display font-bold text-charcoal text-lg">Family-Run</p>
          <p class="text-gray text-sm">Ray, Nehemiah & Chaz</p>
        </div>
        <div class="text-center">
          <div class="w-12 h-12 mx-auto mb-3 bg-forest/10 rounded-full flex items-center justify-center">
            <svg class="w-6 h-6 text-forest" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" />
            </svg>
          </div>
          <p class="font-display font-bold text-charcoal text-lg">Warranty</p>
          <p class="text-gray text-sm">Guaranteed exclusion work</p>
        </div>
      </div>
    </div>
  </section>

  {/* ===== 4-STEP PROCESS ===== */}
  <section class="bg-dark py-16 md:py-24">
    <div class="max-w-container mx-auto px-4 sm:px-6">
      <div class="text-center mb-12 md:mb-16">
        <p class="text-amber font-display font-semibold text-sm uppercase tracking-wider mb-3">Our Proven Method</p>
        <h2 class="text-3xl md:text-4xl font-display font-bold text-white mb-4">The 4-Step ASAP Process</h2>
        <p class="text-white/60 text-lg max-w-2xl mx-auto">
          Most companies trap and leave. We go further. Our complete process is why pests and wildlife stay gone for good.
        </p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
        {site.process.map((step) => (
          <div class="relative text-center">
            <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-amber/10 flex items-center justify-center">
              <span class="text-2xl font-display font-bold text-amber">{step.step}</span>
            </div>
            <h3 class="text-xl font-display font-bold text-white mb-2">{step.title}</h3>
            <p class="text-white/60 text-sm leading-relaxed">{step.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* ===== SERVICES GRID ===== */}
  <section class="py-16 md:py-24 bg-warm-white">
    <div class="max-w-container mx-auto px-4 sm:px-6">
      <div class="text-center mb-12 md:mb-16">
        <p class="text-forest font-display font-semibold text-sm uppercase tracking-wider mb-3">What We Do</p>
        <h2 class="text-3xl md:text-4xl font-display font-bold text-charcoal mb-4">Our Services</h2>
        <p class="text-gray text-lg max-w-2xl mx-auto">
          From a single raccoon to a full commercial infestation, we have the training, licenses, and equipment to handle it.
        </p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {site.services.map(service => (
          <a
            href={`/services/${service.slug}/`}
            class="group bg-white rounded-xl p-6 border border-border hover:border-forest/30 hover:shadow-lg transition-all duration-200"
          >
            <div class="w-12 h-12 mb-4 rounded-lg bg-forest/10 flex items-center justify-center group-hover:bg-forest/20 transition-colors">
              <svg class="w-6 h-6 text-forest" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
            </div>
            <h3 class="text-xl font-display font-bold text-charcoal mb-2 group-hover:text-forest transition-colors">{service.title}</h3>
            <p class="text-gray text-sm leading-relaxed mb-4">{service.description}</p>
            <span class="inline-flex items-center gap-1 text-forest font-display font-semibold text-sm">
              Learn more
              <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path d="M9 5l7 7-7 7" />
              </svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  {/* ===== EMERGENCY CTA ===== */}
  <section class="bg-amber">
    <div class="max-w-container mx-auto px-4 sm:px-6 py-12 md:py-16 text-center">
      <h2 class="text-3xl md:text-4xl font-display font-bold text-dark mb-4">Wildlife Emergency? Call Now.</h2>
      <p class="text-dark/70 text-lg mb-8 max-w-2xl mx-auto">
        Animals in your attic, walls, or crawl space? We respond same day, six days a week. No voicemail -- a real person answers.
      </p>
      <a
        href={`tel:${site.phoneTel}`}
        class="inline-flex items-center gap-3 bg-dark hover:bg-charcoal text-white font-display font-bold px-10 py-5 rounded-lg text-2xl transition-colors shadow-lg"
      >
        <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
        {site.phone}
      </a>
    </div>
  </section>

  {/* ===== TESTIMONIALS ===== */}
  <section class="py-16 md:py-24 bg-light">
    <div class="max-w-container mx-auto px-4 sm:px-6">
      <div class="text-center mb-12 md:mb-16">
        <p class="text-forest font-display font-semibold text-sm uppercase tracking-wider mb-3">Testimonials</p>
        <h2 class="text-3xl md:text-4xl font-display font-bold text-charcoal mb-4">What Our Customers Say</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {testimonials.map(t => (
          <div class="bg-white rounded-xl p-6 border border-border">
            <div class="flex items-center gap-1 mb-4">
              {[1,2,3,4,5].map(() => (
                <svg class="w-5 h-5 text-amber" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
            <p class="text-charcoal text-sm leading-relaxed mb-4">"{t.text}"</p>
            <div>
              <p class="font-display font-bold text-charcoal">{t.name}</p>
              <p class="text-gray text-sm">{t.location}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* ===== SERVICE AREAS ===== */}
  <section class="py-16 md:py-24 bg-warm-white">
    <div class="max-w-container mx-auto px-4 sm:px-6">
      <div class="text-center mb-12 md:mb-16">
        <p class="text-forest font-display font-semibold text-sm uppercase tracking-wider mb-3">Coverage Area</p>
        <h2 class="text-3xl md:text-4xl font-display font-bold text-charcoal mb-4">Serving All of Metro Atlanta</h2>
        <p class="text-gray text-lg max-w-2xl mx-auto">
          We proudly serve Atlanta and surrounding communities. If you are in the Metro Atlanta area, we can help.
        </p>
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-4">
        {site.serviceAreas.map(area => (
          <div class="bg-white rounded-lg px-4 py-3 text-center border border-border">
            <p class="font-display font-medium text-charcoal text-sm">{area}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>
