<script>
  // ===== IntersectionObserver for scroll animations =====
  const observerConfig = { threshold: 0.15, rootMargin: '0px 0px -50px 0px' };

  const scrollObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        scrollObserver.unobserve(entry.target);
      }
    });
  }, observerConfig);

  document.querySelectorAll('.fade-up, .fade-right, .fade-in, .step-line').forEach(el => {
    scrollObserver.observe(el);
  });

  // ===== Hero sequential animation (on load) =====
  const heroTexts = document.querySelectorAll('.hero-text');
  const heroGrid = document.querySelector('.hero-grid');

  heroTexts.forEach((el, i) => {
    const delay = i * 200; // 0ms, 200ms, 400ms
    setTimeout(() => {
      (el as HTMLElement).style.transition = 'opacity 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94), transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94)';
      (el as HTMLElement).style.opacity = '1';
      (el as HTMLElement).style.transform = 'translateY(0)';
    }, delay);
  });

  if (heroGrid) {
    setTimeout(() => {
      (heroGrid as HTMLElement).style.transition = 'opacity 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94), transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94)';
      (heroGrid as HTMLElement).style.opacity = '1';
      (heroGrid as HTMLElement).style.transform = 'translateX(0)';
    }, 300);
  }

  // ===== Counter animation for "100+ Reviews" =====
  const counterEl = document.getElementById('review-counter');
  if (counterEl) {
    const counterObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          let current = 0;
          const target = 100;
          const duration = 1500;
          const stepTime = duration / target;
          const timer = setInterval(() => {
            current++;
            counterEl.textContent = String(current);
            if (current >= target) clearInterval(timer);
          }, stepTime);
          counterObserver.unobserve(entry.target);
        }
      });
    }, observerConfig);
    counterObserver.observe(counterEl);
  }
</script>
