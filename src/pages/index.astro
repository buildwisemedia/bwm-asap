---
import BaseLayout from '../layouts/BaseLayout.astro';
import site from '../data/site.json';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "PestControlService",
  "name": site.name,
  "description": site.description,
  "url": site.url,
  "telephone": site.phoneTel,
  "email": site.email,
  "address": {
    "@type": "PostalAddress",
    "streetAddress": site.address.street,
    "addressLocality": site.address.city,
    "addressRegion": site.address.state,
    "postalCode": site.address.zip,
    "addressCountry": "US"
  },
  "openingHoursSpecification": {
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"],
    "opens": "00:00",
    "closes": "23:59"
  },
  "areaServed": site.serviceAreas.map(area => ({
    "@type": "City",
    "name": area + ", GA"
  })),
  "priceRange": "$$",
  "image": `${site.url}/favicon.svg`,
  "sameAs": []
};

const heroAnimals = [
  { name: 'Raccoon', img: 'https://cdn.prod.website-files.com/61a68c3ac2bbdc9f4c356d55/620abe342381511ec50d164f_raccoon.png' },
  { name: 'Bat', img: 'https://cdn.prod.website-files.com/61a68c3ac2bbdc9f4c356d55/61d9dea30bdf291ad27ebe4a_bat-new.png' },
  { name: 'Snake', img: 'https://cdn.prod.website-files.com/61a68c3ac2bbdc9f4c356d55/61d90636b70812fdd9c9a4d4_snake.png' },
  { name: 'Rat', img: 'https://cdn.prod.website-files.com/61a68c3ac2bbdc9f4c356d55/61d91442697fbdcbe1b4834c_rat-navy.png' },
  { name: 'Bee', img: 'https://cdn.prod.website-files.com/61a68c3ac2bbdc9f4c356d55/61d91a1d697fbd514db4a0cb_bee.png' },
  { name: 'Armadillo', img: 'https://cdn.prod.website-files.com/61a6f04dba9e11e400c344e8/61d9dfc1a96206e79d12f49b_armadillo-new.png' },
];

const animalServices = [
  { name: 'Raccoons', img: 'https://cdn.prod.website-files.com/61a68c3ac2bbdc9f4c356d55/620abe342381511ec50d164f_raccoon.png', desc: 'Attic invasions, chimney entry, and property damage. We trap, remove, and seal every access point.', link: '/services/wildlife-removal/' },
  { name: 'Bats', img: 'https://cdn.prod.website-files.com/61a68c3ac2bbdc9f4c356d55/61d9dea30bdf291ad27ebe4a_bat-new.png', desc: 'Safe exclusion from attics and walls. Licensed bat removal that protects both your home and the colony.', link: '/services/wildlife-removal/' },
  { name: 'Snakes', img: 'https://cdn.prod.website-files.com/61a68c3ac2bbdc9f4c356d55/61d90636b70812fdd9c9a4d4_snake.png', desc: 'Venomous or not, we identify and remove snakes safely. Property inspection to reduce future encounters.', link: '/services/wildlife-removal/' },
  { name: 'Rats & Mice', img: 'https://cdn.prod.website-files.com/61a68c3ac2bbdc9f4c356d55/61d91442697fbdcbe1b4834c_rat-navy.png', desc: 'Complete rodent elimination with entry point sealing. No poisons near your family or pets.', link: '/services/pest-control/' },
  { name: 'Bees & Wasps', img: 'https://cdn.prod.website-files.com/61a68c3ac2bbdc9f4c356d55/61d91a1d697fbd514db4a0cb_bee.png', desc: 'Hive and nest removal from walls, eaves, and ground. Safe relocation when possible.', link: '/services/pest-control/' },
  { name: 'Armadillos', img: 'https://cdn.prod.website-files.com/61a6f04dba9e11e400c344e8/61d9dfc1a96206e79d12f49b_armadillo-new.png', desc: 'Yard destruction and burrowing damage stopped. Humane trapping and property protection.', link: '/services/wildlife-removal/' },
  { name: 'Coyotes', img: 'https://cdn.prod.website-files.com/61a6f04dba9e11e400c344e8/61d906428b986e4f864faf40_coyote.png', desc: 'Property assessments, deterrent installation, and safe removal to protect pets and livestock.', link: '/services/wildlife-removal/' },
  { name: 'Beavers', img: 'https://cdn.prod.website-files.com/61a6f04dba9e11e400c344e8/61d906abb1f71ca87a357fdc_beaver.png', desc: 'Dam and flooding management. Humane removal to protect waterways and property.', link: '/services/wildlife-removal/' },
];

const reviews = [
  { name: 'Mark Carroll', img: 'https://cdn.prod.website-files.com/61a6f04dba9e11e400c344e8/66c3d0f64577ae2196c7b0a9_mark.png', text: 'The service was excellent! Arrived on time, was very professional, and resolved our raccoon problem completely. Highly recommend ASAP to anyone dealing with wildlife.' },
  { name: 'Kelsey Monaghan', img: 'https://cdn.prod.website-files.com/61a6f04dba9e11e400c344e8/66c3d13eeaefe6c85dcd1919_kels.png', text: 'Do yourself a favor and call Chaz! He was thorough, kind, and explained everything. Our bat issue was resolved in one visit.' },
  { name: 'Fred Perry', img: 'https://cdn.prod.website-files.com/61a6f04dba9e11e400c344e8/66c3d1312b389af231fb17c8_fred.png', text: 'Highly skilled and professional technicians. They found entry points we never would have noticed and sealed everything permanently.' },
  { name: 'Charlie Cichetti', img: 'https://cdn.prod.website-files.com/61a6f04dba9e11e400c344e8/6618cff23a1d3019e9217d64_61a6f2ed9cfca84d189112e1_charlie.png', text: 'No more squirrels getting into my attic! ASAP came out, trapped them humanely, and sealed up every gap. Worth every penny.' },
  { name: 'Yashica Marshall', img: 'https://cdn.prod.website-files.com/61a6f04dba9e11e400c344e8/6618cfb447ca0f467ffc212a_6618ccac7bc64886133100a7_yashica.png', text: 'Extremely professional and respectful of our property. The team was on time, efficient, and left everything cleaner than they found it.' },
  { name: 'Benjamin Olmstead', img: 'https://cdn.prod.website-files.com/61a6f04dba9e11e400c344e8/6618cf8b6d0a291ec10e69ad_6618ccac7bc64886133100a8_benjamin.png', text: 'Went above and beyond what we expected. Not only removed the animals but sanitized the entire attic. Exceptional service.' },
];

const commercialLogos = [
  { name: 'Kroger', color: '#0055A1' },
  { name: 'Walmart', color: '#0071CE' },
  { name: 'Amazon', color: '#FF9900' },
  { name: 'Cushman & Wakefield', color: '#C71526' },
  { name: 'KIPP Academy', color: '#006644' },
  { name: 'Tyler Perry Studios', color: '#1B1B1B' },
];
---

<BaseLayout title="Home" jsonLd={jsonLd}>

  {/* ===== 1. HERO ===== */}
  <section class="bg-cream" style="min-height: 80vh;">
    <div class="max-w-container mx-auto px-4 sm:px-6" style="padding-top: clamp(60px, 8vw, 120px); padding-bottom: 72px;">
      <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-16">
        {/* Left — Text (55-60%) */}
        <div class="lg:w-[58%]">
          <h1
            class="font-display text-navy leading-[1.1] mb-0 hero-text"
            style="font-size: clamp(2.75rem, 5.5vw, 4rem); font-weight: 800; opacity: 0; transform: translateY(20px);"
          >
            One Call. Problem Solved.<br />Peace Restored.
          </h1>
          <p
            class="leading-relaxed hero-text"
            style="font-size: clamp(1.125rem, 2vw, 1.375rem); color: #4A4A4A; line-height: 1.6; margin-top: 20px; opacity: 0; transform: translateY(20px);"
          >
            We inspect, trap, seal every entry point, and disinfect — so the problem is solved for good.
          </p>
          <div class="hero-text" style="opacity: 0; transform: translateY(20px);">
            <a
              href={`tel:${site.phoneTel}`}
              class="inline-flex items-center gap-2 text-orange font-display"
              style="font-size: clamp(1.5rem, 3vw, 2rem); font-weight: 700; margin-top: 24px;"
            >
              <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              {site.phone}
            </a>
            <div style="margin-top: 16px;">
              <a
                href="/contact/"
                class="inline-block bg-orange text-white font-display rounded-lg transition-all duration-200 hover:bg-orange-dark hover:shadow-lg"
                style="padding: 18px 36px; font-size: 1.125rem; font-weight: 600; border-radius: 8px;"
                onmouseenter="this.style.transform='translateY(-2px)'; this.style.boxShadow='0 4px 12px rgba(232,122,46,0.3)'"
                onmouseleave="this.style.transform='translateY(0)'; this.style.boxShadow='none'"
              >
                Book Your Free Inspection
              </a>
            </div>
            <p style="font-size: 0.875rem; color: #666; margin-top: 16px;">
              Licensed by GA DNR &middot; 24/6 Availability &middot; 5-Star Rated
            </p>
          </div>
        </div>

        {/* Right — Animal Grid (40-45%) */}
        <div class="lg:w-[42%] hero-grid" style="opacity: 0; transform: translateX(30px);">
          <div class="bg-white rounded-2xl shadow-[0_8px_32px_rgba(27,42,74,0.08)]" style="padding: 32px;">
            <div class="grid grid-cols-3 gap-3 sm:gap-4">
              {heroAnimals.map(animal => (
                <div class="flex items-center justify-center p-2">
                  <img
                    src={animal.img}
                    alt={animal.name}
                    class="w-full max-w-[120px] h-auto object-contain"
                    loading="eager"
                    style="aspect-ratio: 1;"
                  />
                </div>
              ))}
            </div>
            <p class="text-center mt-4" style="font-size: 0.8rem; color: #1B2A4A; letter-spacing: 0.05em; text-transform: uppercase; font-weight: 600;">
              Wildlife &middot; Pest Control &middot; Exclusion &middot; Sanitation
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* ===== 2. TRUST BAR ===== */}
  <section class="bg-navy">
    <div class="max-w-container mx-auto px-4 sm:px-6 py-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-8">
        <div class="text-center fade-up">
          <div class="w-12 h-12 mx-auto mb-3 bg-white/10 rounded-full flex items-center justify-center">
            <svg class="w-6 h-6 text-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <p class="font-display font-bold text-white text-lg">24/6 Service</p>
          <p class="text-white/60 text-sm">Mon-Sat, always on call</p>
        </div>
        <div class="text-center fade-up">
          <div class="w-12 h-12 mx-auto mb-3 bg-white/10 rounded-full flex items-center justify-center">
            <svg class="w-6 h-6 text-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
          </div>
          <p class="font-display font-bold text-white text-lg">State Licensed</p>
          <p class="text-white/60 text-sm">GA DNR & Dept of Agriculture</p>
        </div>
        <div class="text-center fade-up">
          <div class="w-12 h-12 mx-auto mb-3 bg-white/10 rounded-full flex items-center justify-center">
            <svg class="w-6 h-6 text-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
            </svg>
          </div>
          <p class="font-display font-bold text-white text-lg"><span id="review-counter">0</span>+ Reviews</p>
          <p class="text-white/60 text-sm">Five-star rated</p>
        </div>
        <div class="text-center fade-up">
          <div class="w-12 h-12 mx-auto mb-3 bg-white/10 rounded-full flex items-center justify-center">
            <svg class="w-6 h-6 text-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
            </svg>
          </div>
          <p class="font-display font-bold text-white text-lg">Family-Run</p>
          <p class="text-white/60 text-sm">Ray, Nehemiah & Chaz</p>
        </div>
      </div>
    </div>
  </section>

  {/* ===== 3. 4-STEP PROCESS ===== */}
  <section class="bg-cream" style="padding: 72px 0 48px;">
    <div class="max-w-container mx-auto px-4 sm:px-6">
      <div class="text-center" style="margin-bottom: 40px;">
        <p class="text-orange font-display font-semibold text-sm uppercase tracking-wider mb-3">Our Proven Method</p>
        <h2 class="text-3xl md:text-4xl font-display font-bold text-navy">How We Protect Your Home</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 relative">
        {site.process.map((step, i) => (
          <div class="relative text-center fade-up" style={`transition-delay: ${i * 0.2}s;`}>
            {/* Connecting line (desktop only, not on last step) */}
            {i < 3 && (
              <div class="step-line hidden lg:block" style={`transition-delay: ${(i + 1) * 0.3}s;`}></div>
            )}
            <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-orange flex items-center justify-center">
              <span class="text-2xl font-display font-bold text-white">{step.step}</span>
            </div>
            <h3 class="text-xl font-display font-bold text-navy mb-2">{step.title}</h3>
            <p class="text-gray-text text-sm leading-relaxed">{step.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* ===== 4. SERVICES GRID ===== */}
  <section class="bg-cream" style="padding: 72px 0;">
    <div class="max-w-container mx-auto px-4 sm:px-6">
      <div class="text-center" style="margin-bottom: 40px;">
        <p class="text-orange font-display font-semibold text-sm uppercase tracking-wider mb-3">What We Handle</p>
        <h2 class="text-3xl md:text-4xl font-display font-bold text-navy mb-4">What Are You Dealing With?</h2>
        <p class="text-gray text-lg max-w-2xl mx-auto">
          From a single raccoon to a full commercial infestation, we have the training, licenses, and equipment to handle it.
        </p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {animalServices.map((animal, i) => (
          <a
            href={animal.link}
            class="group bg-white rounded-xl p-6 transition-all duration-250 fade-up"
            style={`box-shadow: 0 2px 16px rgba(0,0,0,0.06); border-radius: 12px; transition-delay: ${i * 0.1}s;`}
            onmouseenter="this.style.transform='translateY(-6px)'; this.style.boxShadow='0 12px 32px rgba(0,0,0,0.1)'"
            onmouseleave="this.style.transform='translateY(0)'; this.style.boxShadow='0 2px 16px rgba(0,0,0,0.06)'"
          >
            <div class="w-20 h-20 mx-auto mb-4">
              <img src={animal.img} alt={animal.name} class="w-full h-full object-contain" loading="lazy" />
            </div>
            <h3 class="text-lg font-display font-bold text-navy mb-2 text-center group-hover:text-orange transition-colors">{animal.name}</h3>
            <p class="text-gray-text text-sm leading-relaxed text-center mb-4">{animal.desc}</p>
            <span class="flex items-center justify-center gap-1 text-orange font-display font-semibold text-sm group-hover:text-navy transition-colors">
              Learn More
              <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path d="M9 5l7 7-7 7" />
              </svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  {/* ===== 5. WHY ASAP ===== */}
  <section class="bg-navy" style="padding: 72px 0;">
    <div class="max-w-container mx-auto px-4 sm:px-6">
      <div class="text-center" style="margin-bottom: 40px;">
        <h2 class="text-3xl md:text-4xl font-display font-bold text-white">Why ASAP?</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="text-center fade-up">
          <div class="w-14 h-14 mx-auto mb-4 bg-white/10 rounded-full flex items-center justify-center">
            <svg class="w-7 h-7 text-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
            </svg>
          </div>
          <h3 class="text-xl font-display font-bold text-white mb-2">Humane & Eco-Friendly</h3>
          <p class="text-white/70 text-sm leading-relaxed">No poisons, no cruelty. Licensed by Georgia DNR and Department of Agriculture.</p>
        </div>
        <div class="text-center fade-up" style="transition-delay: 0.15s;">
          <div class="w-14 h-14 mx-auto mb-4 bg-white/10 rounded-full flex items-center justify-center">
            <svg class="w-7 h-7 text-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
          </div>
          <h3 class="text-xl font-display font-bold text-white mb-2">Complete 4-Step Solution</h3>
          <p class="text-white/70 text-sm leading-relaxed">Most companies skip exclusion. We seal every entry point and back it with a warranty.</p>
        </div>
        <div class="text-center fade-up" style="transition-delay: 0.3s;">
          <div class="w-14 h-14 mx-auto mb-4 bg-white/10 rounded-full flex items-center justify-center">
            <svg class="w-7 h-7 text-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-xl font-display font-bold text-white mb-2">24/6 Emergency Response</h3>
          <p class="text-white/70 text-sm leading-relaxed">Wildlife emergencies don't wait for business hours. Neither do we.</p>
        </div>
      </div>
    </div>
  </section>

  {/* ===== 6. REVIEWS — Tyler Perry Studios Featured + Residential ===== */}
  <section class="bg-cream" style="padding: 72px 0;">
    <div class="max-w-container mx-auto px-4 sm:px-6">
      <div class="text-center" style="margin-bottom: 40px;">
        <p class="text-orange font-display font-semibold text-sm uppercase tracking-wider mb-3">Testimonials</p>
        <h2 class="text-3xl md:text-4xl font-display font-bold text-navy">What Our Customers Say</h2>
      </div>

      {/* Tyler Perry Studios — Featured Commercial Testimonial */}
      <div class="relative bg-navy rounded-2xl overflow-hidden fade-up" style="padding: 48px 40px; margin-bottom: 32px; background: linear-gradient(135deg, #1B2A4A 0%, #243556 100%);">
        <span class="absolute select-none pointer-events-none" style="font-size: 6rem; color: rgba(232,122,46,0.2); top: -20px; left: 20px; font-family: Georgia, serif;" aria-hidden="true">&ldquo;</span>
        <blockquote class="relative">
          <p style="font-size: clamp(1.5rem, 3vw, 2rem); font-style: italic; color: white; font-weight: 400; line-height: 1.5; max-width: 900px; margin: 0 auto;">
            "ASAP was incredible to work with. Professional, thorough, and completely resolved our wildlife issue at the studio. Their team went above and beyond to minimize disruption to our operations."
          </p>
          <footer style="color: #E87A2E; font-size: 1.125rem; font-weight: 600; margin-top: 16px; text-align: center;">
            — Mike Reichert, Tyler Perry Studios
          </footer>
        </blockquote>
      </div>

      {/* Residential Review Cards */}
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {reviews.slice(0, 6).map((r, i) => (
          <div class="bg-white rounded-xl p-6 fade-up" style={`box-shadow: 0 2px 16px rgba(0,0,0,0.06); transition-delay: ${i * 0.1}s;`}>
            <div class="flex items-center gap-1 mb-4">
              {[1,2,3,4,5].map(() => (
                <svg class="w-5 h-5 text-orange" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
            <p class="text-charcoal text-sm leading-relaxed mb-4">"{r.text}"</p>
            <div class="flex items-center gap-3">
              <img src={r.img} alt={r.name} class="w-10 h-10 rounded-full object-cover" loading="lazy" />
              <p class="font-display font-bold text-navy">{r.name}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* ===== 7. COMMERCIAL LOGOS ===== */}
