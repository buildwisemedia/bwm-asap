---
import BaseLayout from '../layouts/BaseLayout.astro';
import site from '../data/site.json';
---

<BaseLayout
  title="About Us"
  description="Meet the ASAP Pest and Wildlife Removal team. Family-run, Georgia-licensed, and committed to humane wildlife removal in Metro Atlanta."
>

  {/* Hero with real photo */}
  <section class="bg-forest relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-forest to-dark/80 opacity-90"></div>
    <div class="relative max-w-container mx-auto px-4 sm:px-6 py-16 md:py-24">
      <div class="flex flex-col lg:flex-row items-center gap-12">
        <div class="lg:w-[60%]">
          <h1 class="text-4xl md:text-5xl font-display font-bold text-white mb-4">About ASAP</h1>
          <p class="text-lg text-white/80 max-w-2xl">
            A family-run team built on trust, training, and doing the job right the first time.
          </p>
        </div>
        <div class="lg:w-[40%]">
          <img
            src="/assets/images/photos/asap-technician-truck-hero.jpg"
            alt="Nehemiah from ASAP Pest and Wildlife Removal with the company truck"
            class="rounded-2xl shadow-2xl w-full h-auto object-cover"
            loading="eager"
          />
        </div>
      </div>
    </div>
  </section>

  {/* Our Story */}
  <section class="py-16 md:py-20 bg-warm-white">
    <div class="max-w-container mx-auto px-4 sm:px-6">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-3xl font-display font-bold text-charcoal mb-6">Our Story</h2>
        <div class="space-y-4 text-gray leading-relaxed">
          <p>
            ASAP Pest and Wildlife Removal started with a simple idea: people dealing with wildlife in their homes deserve honest, thorough service from someone who actually cares about the outcome.
          </p>
          <p>
            We are a family-run business. Ray, Nehemiah, and Chaz work together every day to serve homeowners and businesses across Metro Atlanta. When you call ASAP, you are not talking to a call center. You are talking to the people who will actually show up and do the work.
          </p>
          <p>
            We chose this work because we believe in doing it the right way. That means humane removal methods, thorough exclusion work, and complete cleanup. It means showing up when we say we will, explaining what we find, and standing behind our work.
          </p>
          <p>
            Every job follows our 4-step process: Inspect, Trap, Exclude, Disinfect. Most companies stop after step two. We go further because we know that is what it takes to solve the problem for good.
          </p>
        </div>
      </div>
    </div>
  </section>

  {/* Team */}
  <section class="py-16 md:py-20 bg-light">
    <div class="max-w-container mx-auto px-4 sm:px-6">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-display font-bold text-charcoal mb-4">Meet the Team</h2>
        <p class="text-gray text-lg max-w-2xl mx-auto">
          Three family members, one shared commitment: solve the problem and treat every home like our own.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-4xl mx-auto">
        {site.team.map((member, i) => (
          <div class="bg-white rounded-xl p-8 text-center border border-border">
            {i === 1 ? (
              <img
                src="/assets/images/photos/asap-technician-about.jpg"
                alt={`${member.name} - ${member.role}`}
                class="w-20 h-20 mx-auto mb-4 rounded-full object-cover"
                loading="lazy"
              />
            ) : (
              <div class="w-20 h-20 mx-auto mb-4 rounded-full bg-forest/10 flex items-center justify-center">
                <span class="text-2xl font-display font-bold text-forest">{member.name.charAt(0)}</span>
              </div>
            )}
            <h3 class="text-xl font-display font-bold text-charcoal mb-1">{member.name}</h3>
            <p class="text-gray text-sm">{member.role}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* Values */}
  <section class="py-16 md:py-20 bg-warm-white">
    <div class="max-w-container mx-auto px-4 sm:px-6">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-display font-bold text-charcoal mb-4">What We Stand For</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 max-w-5xl mx-auto">
        {[
          { title: "Humane Methods", description: "We use humane trapping and exclusion techniques. Animals are treated with respect throughout the removal process." },
          { title: "Honest Pricing", description: "We explain what we find, what we recommend, and what it costs before we start any work. No surprises." },
          { title: "Thorough Work", description: "We do not cut corners. Our 4-step process ensures the problem is solved completely, not just temporarily." },
          { title: "Licensed & Insured", description: "We are licensed by the Georgia Department of Natural Resources and the Georgia Department of Agriculture." }
        ].map(value => (
          <div class="bg-white rounded-xl p-6 border border-border">
            <h3 class="text-lg font-display font-bold text-charcoal mb-2">{value.title}</h3>
            <p class="text-gray text-sm leading-relaxed">{value.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* Real Work Gallery */}
  <section class="py-16 md:py-20 bg-light">
    <div class="max-w-container mx-auto px-4 sm:px-6">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-display font-bold text-charcoal mb-4">Our Work in the Field</h2>
        <p class="text-gray text-lg max-w-2xl mx-auto">
          Real photos from real jobs. Humane trapping and safe wildlife removal across Metro Atlanta.
        </p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 max-w-4xl mx-auto">
        <div class="rounded-xl overflow-hidden shadow-md">
          <img
            src="/assets/images/photos/slider-1.png"
            alt="Raccoon safely captured in a humane live trap by ASAP"
            class="w-full h-64 object-cover"
            loading="lazy"
          />
        </div>
        <div class="rounded-xl overflow-hidden shadow-md">
          <img
            src="/assets/images/photos/slider-2.png"
            alt="Opossum safely captured in a humane cage trap by ASAP"
            class="w-full h-64 object-cover"
            loading="lazy"
          />
        </div>
        <div class="rounded-xl overflow-hidden shadow-md">
          <img
            src="/assets/images/photos/slider-3.png"
            alt="Snake safely identified and removed by ASAP wildlife team"
            class="w-full h-64 object-cover"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  {/* Certifications */}
  <section class="py-16 md:py-20 bg-dark">
    <div class="max-w-container mx-auto px-4 sm:px-6 text-center">
      <h2 class="text-3xl font-display font-bold text-white mb-4">Licensed & Certified</h2>
      <p class="text-white/60 text-lg mb-8 max-w-2xl mx-auto">
        ASAP Pest and Wildlife Removal holds active licenses from both Georgia regulatory agencies for pest control and wildlife management.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-6">
        {site.licenses.map(license => (
          <div class="bg-white/5 border border-white/10 rounded-xl px-8 py-6">
            <p class="text-white font-display font-semibold">{license}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>
