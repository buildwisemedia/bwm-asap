---
import BaseLayout from '../layouts/BaseLayout.astro';
import site from '../data/site.json';
---

<BaseLayout
  title="Contact Us"
  description="Contact ASAP Pest and Wildlife Removal. Call (770) 691-3636 for same-day service in Metro Atlanta. Available 24/6."
>

  {/* Hero */}
  <section class="bg-forest relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-forest to-dark/80 opacity-90"></div>
    <div class="relative max-w-container mx-auto px-4 sm:px-6 py-16 md:py-24">
      <div class="max-w-3xl">
        <h1 class="text-4xl md:text-5xl font-display font-bold text-white mb-4">Contact Us</h1>
        <p class="text-lg text-white/80 max-w-2xl">
          Have a pest or wildlife problem? We are here to help. Call us directly or fill out the form below.
        </p>
      </div>
    </div>
  </section>

  {/* Contact content */}
  <section class="py-16 md:py-20 bg-warm-white">
    <div class="max-w-container mx-auto px-4 sm:px-6">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-10 lg:gap-12">

        {/* Form - 2 columns */}
        <div class="lg:col-span-2">
          <h2 class="text-2xl font-display font-bold text-charcoal mb-6">Send Us a Message</h2>
          <form name="contact" method="POST" data-netlify="true" class="space-y-6">
            <input type="hidden" name="form-name" value="contact" />

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              <div>
                <label for="name" class="block text-sm font-display font-semibold text-charcoal mb-2">Your Name *</label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  class="w-full px-4 py-3 rounded-lg border border-border bg-white text-charcoal focus:outline-none focus:ring-2 focus:ring-forest focus:border-transparent transition"
                  placeholder="John Smith"
                />
              </div>
              <div>
                <label for="phone" class="block text-sm font-display font-semibold text-charcoal mb-2">Phone Number *</label>
                <input
                  type="tel"
                  id="phone"
                  name="phone"
                  required
                  class="w-full px-4 py-3 rounded-lg border border-border bg-white text-charcoal focus:outline-none focus:ring-2 focus:ring-forest focus:border-transparent transition"
                  placeholder="(770) 555-0123"
                />
              </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              <div>
                <label for="urgency" class="block text-sm font-display font-semibold text-charcoal mb-2">Urgency Level</label>
                <select
                  id="urgency"
                  name="urgency"
                  class="w-full px-4 py-3 rounded-lg border border-border bg-white text-charcoal focus:outline-none focus:ring-2 focus:ring-forest focus:border-transparent transition"
                >
                  <option value="">Select urgency...</option>
                  <option value="emergency">Emergency - Need help today</option>
                  <option value="soon">Soon - Within a few days</option>
                  <option value="routine">Routine - Schedule at convenience</option>
                  <option value="question">Just have a question</option>
                </select>
              </div>
              <div>
                <label for="pest-type" class="block text-sm font-display font-semibold text-charcoal mb-2">Type of Pest</label>
                <select
                  id="pest-type"
                  name="pest-type"
                  class="w-full px-4 py-3 rounded-lg border border-border bg-white text-charcoal focus:outline-none focus:ring-2 focus:ring-forest focus:border-transparent transition"
                >
                  <option value="">Select pest type...</option>
                  <option value="raccoon">Raccoon</option>
                  <option value="squirrel">Squirrel</option>
                  <option value="bat">Bat</option>
                  <option value="snake">Snake</option>
                  <option value="opossum">Opossum</option>
                  <option value="bird">Bird</option>
                  <option value="rat-mouse">Rat / Mouse</option>
                  <option value="roach">Roach</option>
                  <option value="ant">Ant</option>
                  <option value="termite">Termite</option>
                  <option value="dead-animal">Dead Animal</option>
                  <option value="other">Other / Not Sure</option>
                </select>
              </div>
            </div>

            <div>
              <label for="message" class="block text-sm font-display font-semibold text-charcoal mb-2">Tell Us About Your Situation</label>
              <textarea
                id="message"
                name="message"
                rows="5"
                class="w-full px-4 py-3 rounded-lg border border-border bg-white text-charcoal focus:outline-none focus:ring-2 focus:ring-forest focus:border-transparent transition resize-y"
                placeholder="Describe what you're experiencing, where you've noticed the problem, etc."
              ></textarea>
            </div>

            <button
              type="submit"
              class="inline-flex items-center gap-2 bg-forest hover:bg-forest-light text-white font-display font-bold px-8 py-4 rounded-lg text-lg transition-colors"
            >
              Schedule Free Inspection
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path d="M9 5l7 7-7 7" />
              </svg>
            </button>
          </form>
        </div>

        {/* Sidebar */}
        <div>
          {/* Phone - prominent */}
          <div class="bg-amber rounded-xl p-6 mb-6 text-center">
            <p class="text-dark/70 font-display font-semibold text-sm mb-2">Fastest Way to Reach Us</p>
            <a
              href={`tel:${site.phoneTel}`}
              class="inline-flex items-center gap-2 text-dark font-display font-bold text-2xl hover:text-dark/80 transition-colors"
            >
              <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              {site.phone}
            </a>
            <p class="text-dark/60 text-sm mt-2">A real person answers. No voicemail.</p>
          </div>

          {/* Contact details */}
          <div class="bg-white rounded-xl p-6 border border-border space-y-5">
            <div>
              <h3 class="font-display font-bold text-charcoal mb-2">Hours</h3>
              <p class="text-gray text-sm">{site.hours.display}</p>
            </div>
            <div>
              <h3 class="font-display font-bold text-charcoal mb-2">Email</h3>
              <a href={`mailto:${site.email}`} class="text-forest hover:text-forest-light text-sm transition-colors">{site.email}</a>
            </div>
            <div>
              <h3 class="font-display font-bold text-charcoal mb-2">Address</h3>
              <p class="text-gray text-sm">{site.address.full}</p>
            </div>
            <div>
              <h3 class="font-display font-bold text-charcoal mb-2">Service Area</h3>
              <p class="text-gray text-sm">We serve all of Metro Atlanta including {site.serviceAreas.slice(0, 6).join(', ')}, and surrounding communities.</p>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

</BaseLayout>
