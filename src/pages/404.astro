---
import BaseLayout from '../layouts/BaseLayout.astro';
import site from '../data/site.json';
---

<BaseLayout title="Page Not Found" description="The page you are looking for could not be found.">

  <section class="py-20 md:py-32 bg-warm-white">
    <div class="max-w-container mx-auto px-4 sm:px-6 text-center">
      <p class="text-6xl md:text-8xl font-display font-bold text-forest/20 mb-4">404</p>
      <h1 class="text-3xl md:text-4xl font-display font-bold text-charcoal mb-4">Page Not Found</h1>
      <p class="text-gray text-lg mb-8 max-w-lg mx-auto">
        The page you are looking for does not exist or has been moved. Let us help you find what you need.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="/"
          class="inline-flex items-center gap-2 bg-forest hover:bg-forest-light text-white font-display font-bold px-6 py-3 rounded-lg transition-colors"
        >
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
          </svg>
          Go Home
        </a>
        <a
          href={`tel:${site.phoneTel}`}
          class="inline-flex items-center gap-2 bg-amber hover:bg-amber/90 text-dark font-display font-bold px-6 py-3 rounded-lg transition-colors"
        >
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          Call Us: {site.phone}
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
