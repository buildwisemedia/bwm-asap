---
import BaseLayout from '../../layouts/BaseLayout.astro';
import site from '../../data/site.json';

const entryPoints = [
  { area: "Roof & Soffit", description: "Gaps at the roofline, damaged soffits, and open roof vents are the most common entry points for squirrels, raccoons, and bats." },
  { area: "Foundation & Crawl Space", description: "Cracks in foundations, open crawl space vents, and gaps around utility lines allow rats, mice, and snakes easy access." },
  { area: "Attic Vents & Gable Vents", description: "Unscreened or damaged vents are open invitations for birds, bats, and squirrels to move into your attic." },
  { area: "Chimneys", description: "Uncapped chimneys are used by raccoons, birds, and bats. A proper chimney cap keeps wildlife out while maintaining ventilation." },
  { area: "Plumbing & Utility Gaps", description: "Pipes, wires, and HVAC lines create gaps in your exterior walls. Even a half-inch gap is enough for mice to squeeze through." },
  { area: "Doors & Garage Entries", description: "Worn weather stripping, gaps under doors, and damaged garage seals let pests walk right in." }
];

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Exclusion Services",
    "description": "Permanent pest and wildlife exclusion for homes across Metro Atlanta. We seal every entry point so wildlife and pests cannot return.",
    "provider": {
      "@type": "LocalBusiness",
      "@id": `${site.url}/#business`,
      "name": site.name,
    },
    "areaServed": site.serviceAreas.map((area: string) => ({
      "@type": "City",
      "name": `${area}, GA`,
    })),
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": site.url },
      { "@type": "ListItem", "position": 2, "name": "Services", "item": `${site.url}/services/` },
      { "@type": "ListItem", "position": 3, "name": "Exclusion Services" },
    ],
  },
];
---

<BaseLayout
  title="Exclusion Services"
  description="Permanent pest and wildlife exclusion in Metro Atlanta. We seal every entry point so animals cannot return. Call (770) 691-3636."
  jsonLd={jsonLd}
>

  {/* Hero */}
  <section class="bg-forest relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-forest to-dark/80 opacity-90"></div>
    <div class="relative max-w-container mx-auto px-4 sm:px-6 py-16 md:py-24">
      <div class="max-w-3xl">
        <a href="/services/" class="inline-flex items-center gap-1 text-white/60 hover:text-white text-sm font-display mb-4 transition-colors">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M15 19l-7-7 7-7" /></svg>
          All Services
        </a>
        <h1 class="text-4xl md:text-5xl font-display font-bold text-white mb-4">Exclusion Services</h1>
        <p class="text-lg text-white/80 max-w-2xl">
          The step most pest companies skip. We seal every entry point so wildlife and pests cannot return to your home.
        </p>
      </div>
    </div>
  </section>

  {/* Why exclusion matters */}
  <section class="py-16 md:py-20 bg-warm-white">
    <div class="max-w-container mx-auto px-4 sm:px-6">
      <div class="max-w-3xl mx-auto mb-12">
        <h2 class="text-3xl font-display font-bold text-charcoal mb-4 text-center">Why Exclusion Matters</h2>
        <div class="space-y-4 text-gray leading-relaxed">
          <p>
            Trapping removes the animals you have now. Exclusion prevents the ones that come next. Without proper sealing, new wildlife will find the same openings and move right back in.
          </p>
          <p>
            Most pest control companies stop after trapping. At ASAP, exclusion is a core part of every wildlife job. We inspect your entire home, identify every gap, crack, and opening, then seal them with professional-grade materials designed to last.
          </p>
          <p>
            This is what makes our results permanent. It is also why we can stand behind our work with a warranty.
          </p>
        </div>
      </div>

      {/* Entry points */}
      <h3 class="text-2xl font-display font-bold text-charcoal mb-6 text-center">Common Entry Points We Seal</h3>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {entryPoints.map(point => (
          <div class="bg-white rounded-xl p-6 border border-border">
            <h4 class="text-lg font-display font-bold text-charcoal mb-2">{point.area}</h4>
            <p class="text-gray text-sm leading-relaxed">{point.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* CTA */}
  <section class="bg-amber">
    <div class="max-w-container mx-auto px-4 sm:px-6 py-12 md:py-16 text-center">
      <h2 class="text-3xl md:text-4xl font-display font-bold text-dark mb-4">Seal Your Home for Good</h2>
      <p class="text-dark/70 text-lg mb-8 max-w-2xl mx-auto">
        Stop the cycle of removal and re-entry. Call us for a thorough exclusion inspection.
      </p>
      <a
        href={`tel:${site.phoneTel}`}
        class="inline-flex items-center gap-3 bg-dark hover:bg-charcoal text-white font-display font-bold px-10 py-5 rounded-lg text-2xl transition-colors shadow-lg"
      >
        <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
        {site.phone}
      </a>
    </div>
  </section>

</BaseLayout>
