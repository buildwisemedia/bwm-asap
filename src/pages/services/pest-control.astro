---
import BaseLayout from '../../layouts/BaseLayout.astro';
import site from '../../data/site.json';

const pests = [
  {
    name: "Rats & Mice",
    description: "Rodents reproduce quickly and contaminate food, chew wiring, and spread disease. A small problem can become a major infestation in weeks.",
    approach: "We locate nesting areas, set targeted traps, seal all entry points, and sanitize affected areas. Ongoing monitoring is available for persistent problems."
  },
  {
    name: "Roaches",
    description: "Cockroaches are one of the most common household pests in Georgia. They thrive in warm, humid conditions and can trigger allergies and asthma.",
    approach: "We identify the species, treat with targeted applications, and address moisture and sanitation issues that attract roaches. Follow-up treatments ensure complete elimination."
  },
  {
    name: "Ants",
    description: "Fire ants, carpenter ants, and other species are common across Metro Atlanta. Some damage wood structures while others are simply a nuisance.",
    approach: "We trace colonies to their source, apply targeted treatments, and create barriers to prevent re-entry. Carpenter ant damage is assessed and repair guidance provided."
  },
  {
    name: "Termites",
    description: "Termites cause billions of dollars in damage nationwide each year. Georgia's warm climate makes homes especially vulnerable. Early detection is critical.",
    approach: "We perform thorough inspections, identify the termite species, and recommend the most effective treatment. We also help you understand prevention steps."
  },
  {
    name: "Mosquitoes & Ticks",
    description: "These pests carry diseases like West Nile virus and Lyme disease. Standing water and overgrown vegetation make Metro Atlanta yards a prime habitat.",
    approach: "We treat breeding areas, apply barrier treatments to your yard, and advise on landscaping changes that reduce mosquito and tick populations long-term."
  },
  {
    name: "General Pest Control",
    description: "Spiders, silverfish, centipedes, wasps, and other common pests can make your home uncomfortable. Regular treatment keeps them under control.",
    approach: "We inspect your home, treat interior and exterior problem areas, and set up a maintenance plan to keep your home pest-free year-round."
  }
];

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Pest Control",
    "description": "Effective, safe pest control for homes and businesses across Metro Atlanta. We eliminate the problem and keep it from coming back.",
    "provider": {
      "@type": "LocalBusiness",
      "@id": `${site.url}/#business`,
      "name": site.name,
    },
    "areaServed": site.serviceAreas.map((area: string) => ({
      "@type": "City",
      "name": `${area}, GA`,
    })),
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": site.url },
      { "@type": "ListItem", "position": 2, "name": "Services", "item": `${site.url}/services/` },
      { "@type": "ListItem", "position": 3, "name": "Pest Control" },
    ],
  },
];
---

<BaseLayout
  title="Pest Control"
  description="Effective pest control in Metro Atlanta. Rats, mice, roaches, ants, termites, and more. Licensed and guaranteed. Call (770) 691-3636."
  jsonLd={jsonLd}
>

  {/* Hero */}
  <section class="bg-forest relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-forest to-dark/80 opacity-90"></div>
    <div class="relative max-w-container mx-auto px-4 sm:px-6 py-16 md:py-24">
      <div class="max-w-3xl">
        <a href="/services/" class="inline-flex items-center gap-1 text-white/60 hover:text-white text-sm font-display mb-4 transition-colors">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M15 19l-7-7 7-7" /></svg>
          All Services
        </a>
        <h1 class="text-4xl md:text-5xl font-display font-bold text-white mb-4">Pest Control</h1>
        <p class="text-lg text-white/80 max-w-2xl">
          Effective, safe pest control for homes and businesses. We eliminate the problem and keep it from coming back.
        </p>
      </div>
    </div>
  </section>

  {/* Pests */}
  <section class="py-16 md:py-20 bg-warm-white">
    <div class="max-w-container mx-auto px-4 sm:px-6">
      <div class="max-w-3xl mx-auto text-center mb-12">
        <h2 class="text-3xl font-display font-bold text-charcoal mb-4">Pests We Treat</h2>
        <p class="text-gray text-lg leading-relaxed">
          Georgia's warm, humid climate is perfect for pests. Our licensed technicians know exactly how to handle each species and keep your home protected.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {pests.map(pest => (
          <div class="bg-white rounded-xl p-6 md:p-8 border border-border">
            <h3 class="text-xl font-display font-bold text-charcoal mb-3">{pest.name}</h3>
            <p class="text-gray text-sm leading-relaxed mb-4">{pest.description}</p>
            <div class="bg-forest/5 rounded-lg p-4">
              <p class="text-sm font-display font-semibold text-forest mb-1">Our Approach</p>
              <p class="text-charcoal text-sm leading-relaxed">{pest.approach}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* CTA */}
  <section class="bg-amber">
    <div class="max-w-container mx-auto px-4 sm:px-6 py-12 md:py-16 text-center">
      <h2 class="text-3xl md:text-4xl font-display font-bold text-dark mb-4">Pest Problem? We Can Help Today.</h2>
      <p class="text-dark/70 text-lg mb-8 max-w-2xl mx-auto">
        Same-day pest control service available Monday through Saturday.
      </p>
      <a
        href={`tel:${site.phoneTel}`}
        class="inline-flex items-center gap-3 bg-dark hover:bg-charcoal text-white font-display font-bold px-10 py-5 rounded-lg text-2xl transition-colors shadow-lg"
      >
        <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
        {site.phone}
      </a>
    </div>
  </section>

</BaseLayout>
