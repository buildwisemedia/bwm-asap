---
import BaseLayout from '../../layouts/BaseLayout.astro';
import site from '../../data/site.json';

const animals = [
  {
    name: "Raccoons",
    description: "Raccoons are strong, clever, and persistent. They tear open soffits, rip through roof vents, and set up dens in attics. Once inside they cause significant damage to insulation and wiring.",
    approach: "We use humane live traps, relocate animals safely, then seal every entry point they used. We also clean up the mess they leave behind."
  },
  {
    name: "Squirrels",
    description: "Squirrels chew through wood, siding, and electrical wiring to access your attic. A squirrel infestation can create serious fire hazards and structural damage.",
    approach: "We install one-way exclusion doors that let squirrels leave but not return. Once all animals are out, we seal and repair the entry points."
  },
  {
    name: "Bats",
    description: "Bats often roost in attics and wall voids. Their droppings (guano) create health hazards and strong odors. Bats are protected in Georgia, so proper handling is essential.",
    approach: "We perform legal, humane bat exclusion using one-way valves during approved seasons. We then seal all gaps and clean affected areas."
  },
  {
    name: "Snakes",
    description: "Snakes enter homes seeking food, water, or shelter. While most Georgia snakes are harmless, some species are venomous. Either way, you want them out quickly.",
    approach: "We safely capture and remove snakes, identify the species, and address the conditions that attracted them. We seal entry points low to the ground."
  },
  {
    name: "Opossums",
    description: "Opossums shelter under decks, in crawl spaces, and in garages. They can carry parasites and create unsanitary conditions with their droppings.",
    approach: "We use humane traps for safe capture and relocation. Then we secure the areas they used for shelter to prevent future visits."
  },
  {
    name: "Birds",
    description: "Birds nesting in vents, eaves, and attics can block airflow, create fire hazards, and introduce mites and other parasites into your home.",
    approach: "We remove nests from problem areas, install bird exclusion devices, and clean up droppings and nesting materials. We follow all wildlife protection laws."
  }
];

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Wildlife Removal",
    "description": "Humane, licensed wildlife removal for homes and businesses across Metro Atlanta. We remove the animal, seal your home, and clean up after.",
    "provider": {
      "@type": "LocalBusiness",
      "@id": `${site.url}/#business`,
      "name": site.name,
    },
    "areaServed": site.serviceAreas.map((area: string) => ({
      "@type": "City",
      "name": `${area}, GA`,
    })),
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": site.url },
      { "@type": "ListItem", "position": 2, "name": "Services", "item": `${site.url}/services/` },
      { "@type": "ListItem", "position": 3, "name": "Wildlife Removal" },
    ],
  },
];
---

<BaseLayout
  title="Wildlife Removal"
  description="Humane wildlife removal in Metro Atlanta. Raccoons, squirrels, bats, snakes, opossums, and birds. Licensed by Georgia DNR. Call (770) 691-3636."
  jsonLd={jsonLd}
>

  {/* Hero */}
  <section class="bg-forest relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-forest to-dark/80 opacity-90"></div>
    <div class="relative max-w-container mx-auto px-4 sm:px-6 py-16 md:py-24">
      <div class="max-w-3xl">
        <a href="/services/" class="inline-flex items-center gap-1 text-white/60 hover:text-white text-sm font-display mb-4 transition-colors">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M15 19l-7-7 7-7" /></svg>
          All Services
        </a>
        <h1 class="text-4xl md:text-5xl font-display font-bold text-white mb-4">Wildlife Removal</h1>
        <p class="text-lg text-white/80 max-w-2xl">
          Humane, licensed wildlife removal for homes and businesses across Metro Atlanta. We remove the animal, seal your home, and clean up after.
        </p>
      </div>
    </div>
  </section>

  {/* Intro */}
  <section class="py-16 md:py-20 bg-warm-white">
    <div class="max-w-container mx-auto px-4 sm:px-6">
      <div class="max-w-3xl mx-auto text-center mb-12">
        <h2 class="text-3xl font-display font-bold text-charcoal mb-4">We Handle It All</h2>
        <p class="text-gray text-lg leading-relaxed">
          Wildlife in your home is stressful. We make it simple. One call gets you a same-day inspection, humane removal, and permanent exclusion. Every job includes our full 4-step process.
        </p>
      </div>

      {/* Animals */}
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {animals.map(animal => (
          <div class="bg-white rounded-xl p-6 md:p-8 border border-border">
            <h3 class="text-xl font-display font-bold text-charcoal mb-3">{animal.name}</h3>
            <p class="text-gray text-sm leading-relaxed mb-4">{animal.description}</p>
            <div class="bg-forest/5 rounded-lg p-4">
              <p class="text-sm font-display font-semibold text-forest mb-1">Our Approach</p>
              <p class="text-charcoal text-sm leading-relaxed">{animal.approach}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* CTA */}
  <section class="bg-amber">
    <div class="max-w-container mx-auto px-4 sm:px-6 py-12 md:py-16 text-center">
      <h2 class="text-3xl md:text-4xl font-display font-bold text-dark mb-4">Wildlife in Your Home?</h2>
      <p class="text-dark/70 text-lg mb-8 max-w-2xl mx-auto">
        Do not wait for the problem to get worse. Call now for same-day wildlife removal.
      </p>
      <a
        href={`tel:${site.phoneTel}`}
        class="inline-flex items-center gap-3 bg-dark hover:bg-charcoal text-white font-display font-bold px-10 py-5 rounded-lg text-2xl transition-colors shadow-lg"
      >
        <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
        {site.phone}
      </a>
    </div>
  </section>

</BaseLayout>
