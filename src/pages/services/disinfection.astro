---
import BaseLayout from '../../layouts/BaseLayout.astro';
import site from '../../data/site.json';

const hazards = [
  {
    title: "Animal Droppings",
    description: "Raccoon, bat, and rodent droppings carry bacteria, parasites, and fungal spores. Bat guano can cause histoplasmosis, a serious respiratory illness. Proper removal requires protective equipment and careful handling."
  },
  {
    title: "Urine Contamination",
    description: "Animal urine soaks into insulation, drywall, and wood. It creates lasting odors and can attract new animals to the same area. Professional treatment neutralizes the contamination and eliminates the scent."
  },
  {
    title: "Nesting Materials",
    description: "Nests made of leaves, insulation, and other debris harbor parasites like fleas, ticks, and mites. These pests can spread into your living spaces if nesting material is not properly removed."
  },
  {
    title: "Insulation Damage",
    description: "Animals compact, soil, and destroy insulation. Damaged insulation reduces your home's energy efficiency and can harbor contaminants. We remove and replace affected insulation as needed."
  }
];

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Disinfection & Cleanup",
    "description": "Professional wildlife cleanup and disinfection in Metro Atlanta. We remove all contamination left behind by wildlife and pests to protect your family's health.",
    "provider": {
      "@type": "LocalBusiness",
      "@id": `${site.url}/#business`,
      "name": site.name,
    },
    "areaServed": site.serviceAreas.map((area: string) => ({
      "@type": "City",
      "name": `${area}, GA`,
    })),
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": site.url },
      { "@type": "ListItem", "position": 2, "name": "Services", "item": `${site.url}/services/` },
      { "@type": "ListItem", "position": 3, "name": "Disinfection & Cleanup" },
    ],
  },
];
---

<BaseLayout
  title="Disinfection & Cleanup"
  description="Professional wildlife cleanup and disinfection in Metro Atlanta. Droppings removal, urine treatment, and insulation replacement. Call (770) 691-3636."
  jsonLd={jsonLd}
>

  {/* Hero */}
  <section class="bg-forest relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-forest to-dark/80 opacity-90"></div>
    <div class="relative max-w-container mx-auto px-4 sm:px-6 py-16 md:py-24">
      <div class="max-w-3xl">
        <a href="/services/" class="inline-flex items-center gap-1 text-white/60 hover:text-white text-sm font-display mb-4 transition-colors">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M15 19l-7-7 7-7" /></svg>
          All Services
        </a>
        <h1 class="text-4xl md:text-5xl font-display font-bold text-white mb-4">Disinfection & Cleanup</h1>
        <p class="text-lg text-white/80 max-w-2xl">
          The job is not done until your home is clean and safe. We remove all contamination left behind by wildlife and pests.
        </p>
      </div>
    </div>
  </section>

  {/* Intro */}
  <section class="py-16 md:py-20 bg-warm-white">
    <div class="max-w-container mx-auto px-4 sm:px-6">
      <div class="max-w-3xl mx-auto mb-12">
        <h2 class="text-3xl font-display font-bold text-charcoal mb-4 text-center">Protect Your Family's Health</h2>
        <div class="space-y-4 text-gray leading-relaxed">
          <p>
            After wildlife is removed, the mess they leave behind is more than just unpleasant. Animal droppings, urine, and nesting materials carry bacteria, parasites, and fungal spores that pose real health risks to your family.
          </p>
          <p>
            Our disinfection team uses professional-grade sanitizers and protective equipment to thoroughly clean affected areas. We do not just spray and walk away. We remove contaminated materials, treat surfaces, and restore your home to a safe, clean condition.
          </p>
        </div>
      </div>

      {/* Health hazards */}
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {hazards.map(hazard => (
          <div class="bg-white rounded-xl p-6 md:p-8 border border-border">
            <h3 class="text-xl font-display font-bold text-charcoal mb-3">{hazard.title}</h3>
            <p class="text-gray text-base leading-relaxed">{hazard.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* Process */}
  <section class="bg-light py-16 md:py-20">
    <div class="max-w-container mx-auto px-4 sm:px-6 text-center">
      <h2 class="text-3xl font-display font-bold text-charcoal mb-4">Our Cleanup Process</h2>
      <p class="text-gray text-lg mb-10 max-w-2xl mx-auto">
        Thorough, safe, and complete. Here is how we restore your space.
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 max-w-4xl mx-auto">
        {[
          { step: "1", title: "Assess", desc: "Inspect the affected area and identify all contamination." },
          { step: "2", title: "Remove", desc: "Carefully remove droppings, nesting, and damaged materials." },
          { step: "3", title: "Sanitize", desc: "Apply professional-grade disinfectants to all surfaces." },
          { step: "4", title: "Restore", desc: "Replace insulation and repair any remaining damage." }
        ].map(s => (
          <div class="bg-white rounded-xl p-6 border border-border">
            <div class="w-10 h-10 mx-auto mb-3 rounded-full bg-forest/10 flex items-center justify-center">
              <span class="font-display font-bold text-forest">{s.step}</span>
            </div>
            <h3 class="font-display font-bold text-charcoal mb-1">{s.title}</h3>
            <p class="text-gray text-base">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* CTA */}
  <section class="bg-amber">
    <div class="max-w-container mx-auto px-4 sm:px-6 py-12 md:py-16 text-center">
      <h2 class="text-3xl md:text-4xl font-display font-bold text-dark mb-4">Need Wildlife Cleanup?</h2>
      <p class="text-dark/70 text-lg mb-8 max-w-2xl mx-auto">
        We handle the dirty work so you do not have to. Safe, thorough, and guaranteed.
      </p>
      <a
        href={`tel:${site.phoneTel}`}
        class="inline-flex items-center gap-3 bg-dark hover:bg-charcoal text-white font-display font-bold px-10 py-5 rounded-lg text-2xl transition-colors shadow-lg"
      >
        <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
        {site.phone}
      </a>
    </div>
  </section>

</BaseLayout>
