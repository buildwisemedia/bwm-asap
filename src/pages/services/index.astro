---
import BaseLayout from '../../layouts/BaseLayout.astro';
import site from '../../data/site.json';
---

<BaseLayout
  title="Services"
  description="Complete pest control and wildlife removal services in Metro Atlanta. Inspection, trapping, exclusion, and disinfection. Call (770) 691-3636."
>

  {/* Hero */}
  <section class="bg-forest relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-forest to-dark/80 opacity-90"></div>
    <div class="relative max-w-container mx-auto px-4 sm:px-6 py-16 md:py-24">
      <div class="max-w-3xl">
        <h1 class="text-4xl md:text-5xl font-display font-bold text-white mb-4">Our Services</h1>
        <p class="text-lg text-white/80 max-w-2xl">
          From wildlife in your attic to pests in your kitchen, we have the training and equipment to solve it. Every job follows our proven 4-step process.
        </p>
      </div>
    </div>
  </section>

  {/* Services Grid */}
  <section class="py-16 md:py-24 bg-warm-white">
    <div class="max-w-container mx-auto px-4 sm:px-6">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {site.services.map(service => (
          <a
            href={`/services/${service.slug}/`}
            class="group bg-white rounded-xl p-8 border border-border hover:border-forest/30 hover:shadow-lg transition-all duration-200"
          >
            <div class="w-14 h-14 mb-5 rounded-lg bg-forest/10 flex items-center justify-center group-hover:bg-forest/20 transition-colors">
              <svg class="w-7 h-7 text-forest" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
            </div>
            <h2 class="text-2xl font-display font-bold text-charcoal mb-3 group-hover:text-forest transition-colors">{service.title}</h2>
            <p class="text-gray leading-relaxed mb-4">{service.description}</p>
            <span class="inline-flex items-center gap-1 text-forest font-display font-semibold text-sm">
              Learn more
              <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path d="M9 5l7 7-7 7" />
              </svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  {/* Process reminder */}
  <section class="bg-dark py-16 md:py-20">
    <div class="max-w-container mx-auto px-4 sm:px-6 text-center">
      <h2 class="text-3xl font-display font-bold text-white mb-4">Every Job Follows Our 4-Step Process</h2>
      <p class="text-white/60 text-lg mb-8 max-w-2xl mx-auto">
        Inspect. Trap. Exclude. Disinfect. This thorough approach is why our results last.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href={`tel:${site.phoneTel}`}
          class="inline-flex items-center gap-2 bg-amber hover:bg-amber/90 text-dark font-display font-bold px-8 py-4 rounded-lg text-lg transition-colors"
        >
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          Call Now: {site.phone}
        </a>
        <a
          href="/contact/"
          class="inline-flex items-center gap-2 bg-white/10 hover:bg-white/20 text-white font-display font-bold px-8 py-4 rounded-lg text-lg transition-colors border border-white/20"
        >
          Schedule Free Inspection
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
