---
import BaseLayout from '../../layouts/BaseLayout.astro';
import site from '../../data/site.json';

const industries = [
  {
    name: "Restaurants & Food Service",
    description: "Health code compliance is non-negotiable. We provide discreet, scheduled pest management that keeps your kitchen and dining areas pest-free without disrupting service."
  },
  {
    name: "Office Buildings",
    description: "Pests and wildlife in an office create liability and morale issues. We handle everything from rodent control to bird exclusion, working around your business hours."
  },
  {
    name: "Warehouses & Storage",
    description: "Large spaces with multiple entry points are challenging. We design custom exclusion plans and implement ongoing monitoring to protect your inventory."
  },
  {
    name: "Retail Spaces",
    description: "A pest sighting can cost you customers. Our preventive programs keep your store clean and welcoming with regular inspections and treatments."
  },
  {
    name: "Property Management",
    description: "We work with property managers to handle tenant pest complaints quickly and professionally. Volume pricing and priority scheduling available."
  },
  {
    name: "Healthcare Facilities",
    description: "We understand the strict sanitation requirements of medical environments. Our treatments are safe, targeted, and fully documented for your compliance records."
  }
];

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Commercial Pest & Wildlife Services",
    "description": "Discreet, professional pest and wildlife management for businesses across Metro Atlanta. We protect your reputation, your employees, and your bottom line.",
    "provider": {
      "@type": "LocalBusiness",
      "@id": `${site.url}/#business`,
      "name": site.name,
    },
    "areaServed": site.serviceAreas.map((area: string) => ({
      "@type": "City",
      "name": `${area}, GA`,
    })),
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": site.url },
      { "@type": "ListItem", "position": 2, "name": "Services", "item": `${site.url}/services/` },
      { "@type": "ListItem", "position": 3, "name": "Commercial Services" },
    ],
  },
];
---

<BaseLayout
  title="Commercial Pest Management"
  description="Discreet commercial pest and wildlife management in Metro Atlanta. Restaurants, offices, warehouses, and retail. Call (770) 691-3636."
  jsonLd={jsonLd}
>

  {/* Hero */}
  <section class="bg-forest relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-forest to-dark/80 opacity-90"></div>
    <div class="relative max-w-container mx-auto px-4 sm:px-6 py-16 md:py-24">
      <div class="max-w-3xl">
        <a href="/services/" class="inline-flex items-center gap-1 text-white/60 hover:text-white text-sm font-display mb-4 transition-colors">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M15 19l-7-7 7-7" /></svg>
          All Services
        </a>
        <h1 class="text-4xl md:text-5xl font-display font-bold text-white mb-4">Commercial Services</h1>
        <p class="text-lg text-white/80 max-w-2xl">
          Discreet, professional pest and wildlife management for your business. We protect your reputation, your employees, and your bottom line.
        </p>
      </div>
    </div>
  </section>

  {/* Why commercial */}
  <section class="py-16 md:py-20 bg-warm-white">
    <div class="max-w-container mx-auto px-4 sm:px-6">
      <div class="max-w-3xl mx-auto mb-12">
        <h2 class="text-3xl font-display font-bold text-charcoal mb-4 text-center">Pest Control That Protects Your Business</h2>
        <div class="space-y-4 text-gray leading-relaxed">
          <p>
            A pest problem in a commercial setting is more than an inconvenience. It is a risk to your reputation, your health code compliance, and your revenue. We understand the stakes.
          </p>
          <p>
            Our commercial services are designed to be discreet and effective. We work around your business hours, use targeted treatments that are safe for your employees and customers, and provide the documentation you need for inspections and compliance.
          </p>
          <p>
            Whether you need a one-time removal or an ongoing maintenance program, we build a plan that fits your business.
          </p>
        </div>
      </div>

      {/* Industries */}
      <h3 class="text-2xl font-display font-bold text-charcoal mb-6 text-center">Industries We Serve</h3>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {industries.map(industry => (
          <div class="bg-white rounded-xl p-6 border border-border">
            <h4 class="text-lg font-display font-bold text-charcoal mb-2">{industry.name}</h4>
            <p class="text-gray text-sm leading-relaxed">{industry.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* CTA */}
  <section class="bg-amber">
    <div class="max-w-container mx-auto px-4 sm:px-6 py-12 md:py-16 text-center">
      <h2 class="text-3xl md:text-4xl font-display font-bold text-dark mb-4">Protect Your Business</h2>
      <p class="text-dark/70 text-lg mb-8 max-w-2xl mx-auto">
        Get a customized pest management plan for your commercial property. Free consultation.
      </p>
      <a
        href={`tel:${site.phoneTel}`}
        class="inline-flex items-center gap-3 bg-dark hover:bg-charcoal text-white font-display font-bold px-10 py-5 rounded-lg text-2xl transition-colors shadow-lg"
      >
        <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
        {site.phone}
      </a>
    </div>
  </section>

</BaseLayout>
