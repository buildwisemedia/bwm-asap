---
import site from '../data/site.json';

const currentYear = new Date().getFullYear();
---

<footer class="bg-dark text-white/80">
  {/* Footer CTA */}
  <div class="bg-forest">
    <div class="max-w-container mx-auto px-4 sm:px-6 py-12 md:py-16 text-center">
      <h2 class="text-3xl md:text-4xl font-display font-bold text-white mb-4">Ready to Solve Your Pest Problem?</h2>
      <p class="text-white/80 text-lg mb-8 max-w-2xl mx-auto">
        Our licensed team is standing by. Same-day service available Monday through Saturday.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href={`tel:${site.phoneTel}`}
          class="inline-flex items-center gap-2 bg-amber hover:bg-amber/90 text-dark font-display font-bold px-8 py-4 rounded-lg text-lg transition-colors"
        >
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          Call Now: {site.phone}
        </a>
        <a
          href="/contact/"
          class="inline-flex items-center gap-2 bg-white/10 hover:bg-white/20 text-white font-display font-bold px-8 py-4 rounded-lg text-lg transition-colors border border-white/20"
        >
          Schedule Free Inspection
        </a>
      </div>
    </div>
  </div>

  {/* Main footer */}
  <div class="max-w-container mx-auto px-4 sm:px-6 py-12 md:py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-8">
      {/* Brand */}
      <div>
        <a href="/" class="inline-flex items-center gap-1 mb-4">
          <span class="text-2xl font-display font-bold text-amber">ASAP</span>
          <span class="text-sm font-display font-medium text-white leading-tight">Pest &<br />Wildlife</span>
        </a>
        <p class="text-white/60 text-sm leading-relaxed mb-4">{site.tagline}</p>
        <p class="text-white/60 text-sm">Licensed by Georgia DNR<br />& Georgia Dept of Agriculture</p>
      </div>

      {/* Services */}
      <div>
        <h3 class="font-display font-bold text-white mb-4">Services</h3>
        <ul class="space-y-2">
          {site.services.map(s => (
            <li>
              <a href={`/services/${s.slug}/`} class="text-white/60 hover:text-amber transition-colors text-sm">
                {s.title}
              </a>
            </li>
          ))}
        </ul>
      </div>

      {/* Service Areas */}
      <div>
        <h3 class="font-display font-bold text-white mb-4">Service Areas</h3>
        <ul class="grid grid-cols-2 gap-x-4 gap-y-1">
          {site.serviceAreas.map(area => (
            <li class="text-white/60 text-sm">{area}</li>
          ))}
        </ul>
      </div>

      {/* Contact */}
      <div>
        <h3 class="font-display font-bold text-white mb-4">Contact Us</h3>
        <ul class="space-y-3 text-sm">
          <li>
            <a href={`tel:${site.phoneTel}`} class="flex items-center gap-2 text-amber hover:text-amber/80 font-bold text-lg transition-colors">
              <svg class="w-5 h-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              {site.phone}
            </a>
          </li>
          <li>
            <a href={`mailto:${site.email}`} class="flex items-center gap-2 text-white/60 hover:text-amber transition-colors">
              <svg class="w-5 h-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              {site.email}
            </a>
          </li>
          <li class="flex items-start gap-2 text-white/60">
            <svg class="w-5 h-5 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            {site.address.full}
          </li>
          <li class="flex items-center gap-2 text-white/60">
            <svg class="w-5 h-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            {site.hours.display}
          </li>
        </ul>
      </div>
    </div>
  </div>

  {/* Bottom bar */}
  <div class="border-t border-white/10">
    <div class="max-w-container mx-auto px-4 sm:px-6 py-6 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-white/40">
      <p>&copy; {currentYear} {site.name}. All rights reserved.</p>
      <div class="flex items-center gap-6">
        <a href="/privacy/" class="hover:text-white transition-colors">Privacy Policy</a>
        <a href="/terms/" class="hover:text-white transition-colors">Terms of Service</a>
      </div>
    </div>
  </div>
</footer>
